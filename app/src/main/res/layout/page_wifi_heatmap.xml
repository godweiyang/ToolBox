<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/wifi_heatmap_label"
        android:textStyle="bold"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/tvHeatmapEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/wifi_heatmap_empty"
        android:textSize="13sp"
        android:textColor="#999999"
        android:gravity="center"
        android:paddingBottom="8dp"
        android:visibility="gone" />

    <com.example.videodownloader.HeatMapView
        android:id="@+id/heatMap"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FAFAFA" />

    <TextView
        android:id="@+id/tvSteps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="13sp"
        android:textColor="#666666"
        android:paddingTop="8dp"
        android:paddingBottom="4dp" />

    <TextView
        android:id="@+id/tvWalkHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/wifi_heatmap_auto_hint"
        android:textSize="12sp"
        android:textColor="#999999"
        android:paddingBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnToggleHeat"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/wifi_btn_start"
            android:backgroundTint="@color/tool_wifi_bg"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/btnResetView"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/wifi_heatmap_reset_view"
            android:layout_marginStart="8dp" />

        <Button
            android:id="@+id/btnClear"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/wifi_heatmap_clear"
            android:layout_marginStart="8dp" />
    </LinearLayout>

</LinearLayout>
