<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/tool_metal_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="12dp" />

        <!-- 当前磁场强度大数字 -->
        <TextView
            android:id="@+id/tvCurrent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0.0 μT"
            android:textSize="60sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="@color/metal_normal"
            android:paddingTop="16dp"
            android:paddingBottom="4dp" />

        <!-- 三轴数据 -->
        <TextView
            android:id="@+id/tvAxis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="X: 0.0    Y: 0.0    Z: 0.0 μT"
            android:textSize="13sp"
            android:textColor="#666666"
            android:gravity="center"
            android:paddingBottom="8dp" />

        <!-- 等级标签 -->
        <TextView
            android:id="@+id/tvLevel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/metal_hint"
            android:textSize="16sp"
            android:gravity="center"
            android:textStyle="bold"
            android:paddingBottom="16dp" />

        <!-- 磁场强度条 -->
        <ProgressBar
            android:id="@+id/levelBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:max="200"
            android:progress="0" />

        <!-- 阈值滑块 -->
        <TextView
            android:id="@+id/tvThreshold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/metal_threshold"
            android:textSize="13sp"
            android:textColor="#666666"
            android:layout_marginTop="16dp"
            android:paddingBottom="4dp" />

        <SeekBar
            android:id="@+id/sbThreshold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="200"
            android:progress="60" />

        <!-- 最小 / 平均 / 最大 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:weightSum="3">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="最小"
                    android:textColor="#666666"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvMin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="平均"
                    android:textColor="#666666"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvAvg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="最大"
                    android:textColor="#666666"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvMax"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- 实时波形图标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/metal_chart_label"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:paddingBottom="6dp" />

        <!-- 波形图自定义 View -->
        <com.example.videodownloader.MetalChartView
            android:id="@+id/chartView"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:background="#1A000000" />

        <Button
            android:id="@+id/btnToggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/metal_btn_start"
            android:layout_marginTop="20dp"
            android:backgroundTint="@color/tool_metal_bg"
            android:textColor="@android:color/white" />

    </LinearLayout>
</ScrollView>
