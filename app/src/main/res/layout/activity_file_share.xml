<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/tool_fileshare_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="12dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/fs_status_off"
            android:gravity="center"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#888888"
            android:paddingBottom="12dp" />

        <Button
            android:id="@+id/btnToggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/fs_btn_start"
            android:backgroundTint="@color/tool_fileshare_bg"
            android:textColor="@android:color/white" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/fs_qr_hint"
            android:gravity="center"
            android:textSize="13sp"
            android:textColor="#666666"
            android:layout_marginTop="20dp"
            android:paddingBottom="8dp" />

        <ImageView
            android:id="@+id/ivQrCode"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:layout_gravity="center"
            android:background="#FFFFFF"
            android:scaleType="fitCenter"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/tool_fileshare_bg"
            android:paddingTop="12dp"
            android:visibility="gone" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/fs_same_wifi_hint"
            android:gravity="center"
            android:textSize="12sp"
            android:textColor="#999999"
            android:paddingTop="8dp"
            android:visibility="visible" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/fs_received"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="24dp"
            android:paddingBottom="6dp" />

        <TextView
            android:id="@+id/tvReceivedCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/fs_no_files"
            android:textColor="#888888"
            android:textSize="13sp"
            android:paddingBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvReceived"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

    </LinearLayout>
</ScrollView>
